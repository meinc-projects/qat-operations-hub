# ===========================================
# QAT Operations Hub — Environment Variables
# ===========================================

# --- Zoho OAuth 2.0 ---
# Single Self Client covers all Zoho APIs
# Required scopes: ZohoCRM.modules.deals.ALL, ZohoCRM.modules.contacts.ALL,
#   ZohoCRM.modules.accounts.ALL, ZohoCRM.settings.ALL, ZohoCRM.coql.READ, ZohoCRM.files.READ
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_CRM_API_DOMAIN=https://www.zohoapis.com
ZOHO_CRM_ACCOUNTS_DOMAIN=https://accounts.zoho.com

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=

# --- Microsoft Teams ---
TEAMS_WEBHOOK_URL=

# --- Hub Server ---
HUB_HOST=0.0.0.0
HUB_PORT=8100
LOG_LEVEL=INFO

# --- Module 1: Renewal Backfill ---
# CRITICAL: Leave dry_run=true until you've reviewed a dry run output
BACKFILL_DRY_RUN=true
BACKFILL_BATCH_SIZE=50
BACKFILL_YEAR=2025
BACKFILL_RENEWAL_YEAR=2026
BACKFILL_DAYS_BEFORE_EXPIRY=45
# Skip renewal deal creation (Step 6). Set to false when ready to create renewal deals.
BACKFILL_SKIP_RENEWALS=true

# --- CRM Field API Names ---
# These are assumed defaults. Run test_connection.py to validate.
# If a field name is different in your CRM, update it here.
CRM_FIELD_EXPIRATION_DATE=Expiration_Date
CRM_FIELD_VIN=VIN
# Single combined Year Make Model field
CRM_FIELD_VEHICLE_YMM=Year_Make_Model
CRM_FIELD_STAGE=Stage
CRM_FIELD_CONTACT=Contact_Name
CRM_FIELD_AMOUNT=Amount
CRM_FIELD_CLOSING_DATE=Closing_Date

# --- Google Sheets (for audit reports) ---
# OAuth 2.0 Desktop credentials downloaded from Google Cloud Console
# First run opens a browser for sign-in; token is saved to google_token.json
GOOGLE_OAUTH_CREDENTIALS=oauth_credentials.json
# Folder ID from the Google Drive URL: https://drive.google.com/drive/folders/<THIS_PART>
GOOGLE_DRIVE_FOLDER_ID=

# --- RingCentral (Future modules — not required for Module 1) ---
# RC_CLIENT_ID=
# RC_CLIENT_SECRET=
# RC_JWT=
# RC_FROM_NUMBER=

# --- Zoho Books (Future modules — not required for Module 1) ---
